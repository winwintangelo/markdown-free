# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
.next/
out/
build/
dist/

# Testing
coverage/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel
vercel.json

# Chromium binary (generated during build)
public/chromium-pack.tar

# Temporary files (test results, reports, drafts)
tmp/

# Misc
*.log

# .claude: keep personal/local config (settings.local.json) out, but commit the
# shared growth-loop config (deny-list, /growth-loop command, growth-analyst agent).
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/agents/

# Growth loop: credentials + raw data drops — never commit
*gsc-key*.json
*service-account*.json
/data/drops/
# Per-cycle HTML reports are regenerable views — commit the .md, not the .html
/data/reports/*.html
