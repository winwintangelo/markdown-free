# Umami Analytics (for tracking on the website)
NEXT_PUBLIC_UMAMI_HOST=https://cloud.umami.is
NEXT_PUBLIC_UMAMI_WEBSITE_ID=<your-website-id>

# Umami API (for report generation script)
# NOTE: free Umami Cloud no longer includes API access — `npm run report` will 401.
# On-site analytics now come from the Vercel Analytics dashboard CSV export.
UMAMI_API_KEY=<your-umami-api-key>
UMAMI_WEBSITE_ID=<your-website-id>
UMAMI_API_HOST=https://api.umami.is
REPORT_DAYS=30

# Bing Webmaster Tools API (for `npm run report:bing` — search query/position data)
# This is the GSC-equivalent for the Bing / cn.bing / Chinese-AI channel that
# Google Search Console can't see (our largest audience, CN, arrives via Bing).
# Get the key: https://www.bing.com/webmasters → verify site → Settings (gear)
#   → "API access" → Generate. Then paste it below.
BING_API_KEY=<your-bing-webmaster-api-key>
# Exact verified site URL as shown in Bing Webmaster Tools (try with/without
# trailing slash if you get an "invalid site" error). Default: https://www.markdown.free
BING_SITE_URL=https://www.markdown.free

# Security: HSTS preload directive (production only)
# Leave unset/false until the domain is registered at https://hstspreload.org
# and confirmed in the preload list. Enabling without registration commits
# browsers to HTTPS-only for ~1 year with no quick rollback.
HSTS_PRELOAD_ENABLED=false