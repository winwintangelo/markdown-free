{
  "name": "markdown-free",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:production": "playwright test --config=playwright.production.config.ts",
    "test:production:headed": "playwright test --config=playwright.production.config.ts --headed",
    "postinstall": "node scripts/postinstall.mjs",
    "report": "node scripts/umami-report.mjs",
    "report:sessions": "node scripts/umami-sessions.mjs",
    "validate": "node scripts/validate-production.mjs",
    "validate:verbose": "node scripts/validate-production.mjs --verbose",
    "validate:traffic": "node scripts/validate-production.mjs --simulate-traffic --verbose",
    "indexnow": "node scripts/indexnow-submit.mjs",
    "indexnow:new": "node scripts/indexnow-submit.mjs --new",
    "indexnow:all": "node scripts/indexnow-submit.mjs --all"
  },
  "dependencies": {
    "@sparticuz/chromium-min": "^141.0.0",
    "@vercel/analytics": "^1.6.1",
    "clsx": "^2.1.1",
    "html-to-docx": "^1.8.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.14",
    "puppeteer-core": "^23.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^2.6.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sparticuz/chromium": "^141.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8.5.8",
    "puppeteer": "^23.11.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2"
  }
